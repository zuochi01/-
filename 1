from astrbot.api.event import filter, AstrMessageEvent
from astrbot.api.star import Context, Star, register
from astrbot.api import logger

@register("auto_accept_friend", "YourName", "自动同意好友申请的插件", "v1.0.0")
class AutoAcceptFriend(Star):
    def __init__(self, context: Context):
        super().__init__(context)

    # 使用 event_listener 监听所有事件，然后在函数内判断事件类型
    @filter.event_listener()
    async def on_friend_request(self, event: AstrMessageEvent):
        # 1. 获取事件的原始消息对象
        raw_message = event.message_obj
        
        # 2. 检查事件类型是否为 'request' 且子类型为 'friend'
        #    注意：这里的字段名（如 'request_type'）可能需要根据你的协议端实际推送的 JSON 字段微调
        if raw_message.type == 'request' and raw_message.raw.get('request_type') == 'friend':
            # 3. 提取请求者的信息（用于日志记录）
            user_id = raw_message.raw.get('user_id')
            comment = raw_message.raw.get('comment', '')
            flag = raw_message.raw.get('flag') # 同意请求时需要的标识
            
            # 4. 记录日志并执行同意操作
            if user_id:
                logger.info(f"收到来自 {user_id} 的好友申请，留言: {comment}，正在自动同意...")
                
                # ⚠️ 关键步骤：调用协议端的API来同意请求
                await self.agree_friend_request(flag, user_id)
            
            # 5. 阻止事件继续传播，避免其他插件处理
            event.stop_event()

    async def agree_friend_request(self, flag: str, user_id: str):
        """通过平台适配器调用底层API，同意好友请求"""
        # 这是伪代码，需要找到调用你所用协议端API的正确方法
        # 可能需要通过 self.context.platform 或其他方式获取适配器实例
        try:
            # 示例调用，实际函数名和参数请参考你的适配器文档
            # await self.context.platform_adapter.call_api('set_friend_add_request', flag=flag, approve=True)
            logger.info(f"已成功同意用户 {user_id} 的好友申请。")
        except Exception as e:
            logger.error(f"同意好友申请失败 (用户: {user_id}): {e}")
